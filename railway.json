{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "PYTHON",
    "pythonVersion": "3.13"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "runCommand": "gunicorn --bind 0.0.0.0:$PORT run:app --timeout 120 --workers 2"
  }
}
